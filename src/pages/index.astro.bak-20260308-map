--- import path from "node:path";
import { readFile, stat } from "node:fs/promises";
import { parseCSV } from "../lib/csv";

// ===== CSV =====
const csvText = await readFile(
  new URL("../../data/tech.csv", import.meta.url),
  "utf-8"
);
const tech = parseCSV(csvText);

// 並び：分野→★多い順→タイトル
tech.sort((a, b) => {
  const c = (a.category ?? "").localeCompare(b.category ?? "");
  if (c !== 0) return c;
  const sa = (a.near ?? "").length;
  const sb = (b.near ?? "").length;
  if (sb !== sa) return sb - sa;
  return (a.title ?? "").localeCompare(b.title ?? "");
});

// 分野ごとにまとめる
const groups = new Map<string, typeof tech>();
for (const t of tech) {
  const key = t.category ?? "その他";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(t);
}
const categories = Array.from(groups.keys()).sort((a, b) => a.localeCompare(b));

// ===== 文字列整形 =====
const normalize = (s?: string | null) =>
  (s ?? "").toString().replace(/\r\n/g, "\n").trim();


const short = (s?: string | null, n: number = 120) => {
  const t = normalize(s)
    .replace(/\n+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  if (!t) return "";
  return t.length > n ? t.slice(0, n) + "…" : t;
};
// 一覧用：Markdown“っぽく”描画（安全：HTMLは使わない）
const toBlocks = (s?: string | null) => {
  const text = normalize(s);
  if (!text) return [];

  const lines = text.split("\n");
  const blocks: Array<
    | { type: "p"; text: string }
    | { type: "ul"; items: string[] }
    | { type: "ol"; items: string[] }
  > = [];

  let pBuf: string[] = [];
  let ulBuf: string[] = [];
  let olBuf: string[] = [];

  const flushP = () => {
    const t = pBuf.join(" ").trim();
    if (t) blocks.push({ type: "p", text: t });
    pBuf = [];
  };
  const flushUL = () => {
    if (ulBuf.length) blocks.push({ type: "ul", items: ulBuf });
    ulBuf = [];
  };
  const flushOL = () => {
    if (olBuf.length) blocks.push({ type: "ol", items: olBuf });
    olBuf = [];
  };

  for (const raw of lines) {
    const line = raw.trim();
    if (!line) {
      flushP();
      flushUL();
      flushOL();
      continue;
    }

    const mOl = line.match(/^(\d+)\.\s+(.*)$/);
    const mUl = line.match(/^[-*]\s+(.*)$/);

    if (mOl) {
      flushP();
      flushUL();
      olBuf.push(mOl[2].trim());
      continue;
    }
    if (mUl) {
      flushP();
      flushOL();
      ulBuf.push(mUl[1].trim());
      continue;
    }

    flushUL();
    flushOL();
    pBuf.push(line);
  }

  flushP();
  flushUL();
  flushOL();
  return blocks;
};

const safeHref = (slug?: string | null) => (slug ? `/tech/${slug}` : null);

// ===== Markdown(frontmatter) を直読みして要約Mapを作る =====
const catDir =
  (cat?: string | null) =>
    (cat ?? "").trim() === "エネルギー"
      ? "energy"
      : (cat ?? "").trim() === "環境"
      ? "environment"
      : (cat ?? "").trim() === "医療"
      ? "medical"
      : (cat ?? "").trim() === "食"
      ? "food"
      : (cat ?? "").trim() === "情報"
      ? "info"
      : "misc";

type Summary = {
  life_change?: string;
  solid_result?: string;
  remaining_issues?: string;
  watch_points?: string;
};

function parseFrontmatter(md: string): Record<string, string> {
  const text = (md ?? "").replace(/^\uFEFF/, "");
  const m = text.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n/);
  if (!m) return {};
  const body = m[1];

  const out: Record<string, string> = {};
  for (const line of body.split(/\r?\n/)) {
    const t = line.trim();
    if (!t) continue;
    const mm = t.match(/^([A-Za-z0-9_]+)\s*:\s*(.*)$/);
    if (!mm) continue;
    const key = mm[1];
    let val = mm[2].trim();
    // "..." を外す（簡易）
    if (val.startsWith('"') && val.endsWith('"')) val = val.slice(1, -1);
    out[key] = val;
  }
  return out;
}

const summaryByKey = new Map<string, Summary>();
const mdExistsByKey = new Map<string, boolean>();

await Promise.all(
  tech.map(async (t) => {
    const slug = (t.slug ?? "").trim();
    const cat = (t.category ?? "").trim();
    if (!slug || !cat) return;

    const key = `${cat}/${slug}`;
    const mdPath = path.join(
      process.cwd(),
      "content",
      "tech",
      catDir(cat),
      `${slug}.md`
    );

    try {
      await stat(mdPath);
      mdExistsByKey.set(key, true);
      const mdText = await readFile(mdPath, "utf-8");
      const fm = parseFrontmatter(mdText);

      summaryByKey.set(key, {
        life_change: fm.life_change,
        solid_result: fm.solid_result,
        remaining_issues: fm.remaining_issues,
        watch_points: fm.watch_points,
      });
    } catch {
      mdExistsByKey.set(key, false);
    }
  })
);

const existsOf = (cat?: string | null, slug?: string | null) => {
  const c = (cat ?? "").trim();
  const s = (slug ?? "").trim();
  if (!c || !s) return false;
  return mdExistsByKey.get(`${c}/${s}`) ?? false;
};

const getSummary = (cat?: string | null, slug?: string | null): Summary => {
  const c = (cat ?? "").trim();
  const s = (slug ?? "").trim();
  if (!c || !s) return {};
  return summaryByKey.get(`${c}/${s}`) ?? {};
};
