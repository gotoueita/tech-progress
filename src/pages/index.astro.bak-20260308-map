      .eta { white-space: nowrap; font-weight: 700; color: #333; }

      .title { min-width: 220px; }
      .titleRow { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      .sub { font-size: 11px; color: #777; margin-top: 4px; }

      .link {
        color: inherit;
