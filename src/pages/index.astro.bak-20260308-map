        border-bottom: 1px dotted #aaa;
        font-weight: 800;
      }
      .link:hover { border-bottom-style: solid; }
      .nolink { font-weight: 800; color: #333; }

      .badgeMissing {
        font-size: 11px;
        font-weight: 900;
        color: #7c2d12;
        background: #ffedd5;
        border: 1px solid #fed7aa;
        padding: 2px 6px;
        border-radius: 999px;
        white-space: nowrap;
      }

      .cell { display: grid; gap: 6px; }
      .p { margin: 0; }
      .ul, .ol { margin: 0; padding-left: 18px; }
      .ul li, .ol li { margin: 2px 0; }
      .dim { color: #888; }
    </style>
  </body>
