<html lang="ja">
  


<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>人類の生活を大きく変えうる近未来技術　進捗ボード</title>
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" 
data-cf-beacon='{"token":"6ed43d34957a49fcb90ec8e43f7db523"}'></script>
  </head>

  <body>
    <div class="wrap">
      <header class="head">
        <h1>人類の生活を大きく変えうる近未来技術　進捗ボード</h1>
        <p class="legend">★は現在地の目安（★★★＝実装拡大、★★＝実証段階、★＝研究段階）</p>
        <p class="note">生活変化・現状の成果・実用化の壁・今後の注目点・目安 を整理した進捗ボード</p>
      </header>

      {categories.map((cat) => {
        const rows = groups.get(cat)!;
        const total = rows.length;

        const missing = rows.filter((t) => {
          const slug = (t.slug ?? "").trim();
          if (!slug) return false;
          return !existsOf(t.category ?? null, slug);
        }).length;

        return (
          <section class="section">
            <div class="band">
              <h2>
                {cat}
                <span class="count">（{total}）</span>
                {missing > 0 && <span class="missingCount">未作成 {missing}</span>}
              </h2>
            </div>

            <div class="tableWrap">
              <table>
                <thead>
                  <tr>
                    <th class="colNear">実用化段階</th>
                    <th class="colTitle">技術</th>
                    <th class="colLife">生活変化</th>
                    <th class="colNow">現状の成果</th>
                    <th class="colOpen">実用化の壁</th>
                    <th class="colWatch">今後の注目点</th>
                    <th class="colEta">目安</th>
                  </tr>
                </thead>

                <tbody>
                  {rows.map((t) => {
                    const slug = (t.slug ?? "").trim();
                    const href = safeHref(slug);
                    const isMissing = slug ? !existsOf(t.category ?? null, slug) : false;

                    const s = getSummary(t.category ?? null, slug);

                    // frontmatter優先（CSVに同列が無くてもOK）
                    const lifeBlocks = toBlocks(short(s.life_change));
                    const nowBlocks = toBlocks(short(s.solid_result));
                    const openBlocks = toBlocks(short(s.remaining_issues));
                    const watchBlocks = toBlocks(short(s.watch_points));

                    const renderBlocks = (blocks: any[]) => (
                      <div class="cell">
                        {blocks.length === 0 ? (
                          <span class="dim">—</span>
                        ) : (
                          blocks.map((b) => {
                            if (b.type === "p") return <p class="p">{b.text}</p>;
                            if (b.type === "ul") return <ul class="ul">{b.items.map((x: string) => <li>{x}</li>)}</ul>;
                            if (b.type === "ol") return <ol class="ol">{b.items.map((x: string) => <li>{x}</li>)}</ol>;
                            return null;
                          })
                        )}
                      </div>
                    );

                    return (
                      <tr>
                        <td class="near">{t.near ?? ""}</td>

                        <td class="title">
                          <div class="titleRow">
                            {href ? (
                              <a class="link" href={href}>{t.title}</a>
                            ) : (
                              <span class="nolink">{t.title ?? "(no title)"}</span>
                            )}
                            {slug && isMissing && <span class="badgeMissing">未作成</span>}
                          </div>
                          {slug && <div class="sub">{slug}</div>}
                        </td>

                        <td>{renderBlocks(lifeBlocks)}</td>
                        <td>{renderBlocks(nowBlocks)}</td>
                        <td>{renderBlocks(openBlocks)}</td>
                        <td>{renderBlocks(watchBlocks)}</td>
                        <td class="eta">{t.eta}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </section>
        );
      })}
    </div>

    <style>
      :global(body) {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, "Hiragino Sans", "Noto Sans JP", sans-serif;
        line-height: 1.55;
