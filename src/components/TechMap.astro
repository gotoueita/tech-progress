---
interface Item {
  slug: string;
  title: string;
  category: string;
}

const { items = [] } = Astro.props as { items: Item[] };

const order = ["エネルギー", "医療", "環境", "情報", "食"];

const grouped = order.map((category) => ({
  category,
  items: items.filter((item) => item.category === category),
}));
---

<section class="techMap">
  <h2>技術マップ</h2>
  <p class="techMapLead">技術を分野ごとに整理して俯瞰できるようにした一覧です。</p>

  <div class="techMapGrid">
    {grouped.map((group) => (
      <section class="techMapCard">
        <h3>{group.category}</h3>
        <ul>
          {group.items.map((item) => (
            <li>
              <a href={`/tech/${item.slug}/`}>{item.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</section>

<style>
  .techMap {
    margin: 40px 0 28px;
    padding: 24px;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    background: #fafafa;
  }

  .techMap h2 {
    margin: 0 0 8px;
    font-size: 1.6rem;
  }

  .techMapLead {
    margin: 0 0 20px;
    color: #555;
    line-height: 1.7;
  }

  .techMapGrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .techMapCard {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 16px;
  }

  .techMapCard h3 {
    margin: 0 0 12px;
    font-size: 1.05rem;
  }

  .techMapCard ul {
    margin: 0;
    padding-left: 18px;
  }

  .techMapCard li + li {
    margin-top: 6px;
  }

  .techMapCard a {
    text-decoration: none;
  }

  .techMapCard a:hover {
    text-decoration: underline;
  }
</style>
